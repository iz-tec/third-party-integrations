# Copy this file to .env and fill in the values before running docker compose up

# --- Database (TimescaleDB / PostgreSQL) ---
DB_NAME=integrations_db
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# --- integration-tns image version ---
TNS_IMAGE_VERSION=1.0.0-SNAPSHOT

# --- TNS API credentials ---
TNS_BASE_URL=https://api.lsm-dev.tnsi.com.br
TNS_USERNAME=your-tns-username
TNS_PASSWORD=your-tns-password

